generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Locale {
  EN
  ZH
}

enum Theme {
  SYSTEM
  LIGHT
  DARK
}

enum TimeFormat {
  H12
  H24
}

enum Mood {
  ROMANTIC
  HAPPY
  PEACEFUL
  EXCITED
  NOSTALGIC
  GRATEFUL
  TENDER
}

enum MembershipRole {
  OWNER
  PARTNER
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

enum AnniversaryType {
  COUNTDOWN
  COUNTUP
}

enum WishlistStatus {
  DREAMING
  PLANNING
  COMPLETED
}

enum AssetStatus {
  PENDING
  PROCESSED
  FAILED
}

enum NotificationChannel {
  IN_APP
  WEB_PUSH
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  displayName               String?
  locale                    Locale                     @default(ZH)
  theme                     Theme                      @default(SYSTEM)
  timeFormat                TimeFormat                 @default(H24)
  timezone                  String                     @default("Asia/Shanghai")
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  membership                Membership?
  passkeys                  PasskeyCredential[]
  sessions                  Session[]
  authChallenges            AuthChallenge[]
  recoveryTokens            RecoveryToken[]
  authoredMemories          Memory[]                   @relation("MemoryAuthor")
  authoredAssets            MemoryAsset[]              @relation("AssetAuthor")
  authoredWishlistItems     WishlistItem[]             @relation("WishlistAuthor")
  createdInvites            PairingInvite[]            @relation("InviteCreator")
  notificationSubscriptions NotificationSubscription[]
  notificationRecords       NotificationRecord[]
  auditLogs                 AuditLog[]
}

model CoupleSpace {
  id                  String               @id @default(cuid())
  slug                String               @unique
  title               String
  createdById         String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         Membership[]
  invites             PairingInvite[]
  memories            Memory[]
  memoryAssets        MemoryAsset[]
  anniversaries       Anniversary[]
  wishlistItems       WishlistItem[]
  notificationRecords NotificationRecord[]
  auditLogs           AuditLog[]
}

model Membership {
  id            String           @id @default(cuid())
  userId        String           @unique
  coupleSpaceId String
  role          MembershipRole
  status        MembershipStatus @default(ACTIVE)
  seatNumber    Int?
  joinedAt      DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleSpace   CoupleSpace      @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)

  @@unique([coupleSpaceId, seatNumber])
  @@index([coupleSpaceId, status])
}

model PasskeyCredential {
  id             String   @id @default(cuid())
  userId         String
  webAuthnUserId String
  credentialId   String   @unique
  publicKey      Bytes    @db.LongBlob
  counter        Int      @default(0)
  transports     String?  @db.Text
  deviceType     String?
  backedUp       Boolean?
  label          String?
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?  @db.Text
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthChallenge {
  id         String   @id @default(cuid())
  userId     String
  kind       String
  challenge  String   @db.Text
  rpId       String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
}

model RecoveryToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PairingInvite {
  id            String      @id @default(cuid())
  code          String      @unique
  coupleSpaceId String
  createdById   String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())
  coupleSpace   CoupleSpace @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)
  createdBy     User        @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([coupleSpaceId, expiresAt])
}

model Memory {
  id            String        @id @default(cuid())
  coupleSpaceId String
  authorId      String
  title         String
  story         String        @db.Text
  occurredAt    DateTime
  sortAt        DateTime
  mood          Mood
  locationName  String?
  latitude      Decimal?      @db.Decimal(10, 7)
  longitude     Decimal?      @db.Decimal(10, 7)
  coverAssetId  String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  coupleSpace   CoupleSpace   @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)
  author        User          @relation("MemoryAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  coverAsset    MemoryAsset?  @relation("MemoryCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  assets        MemoryAsset[] @relation("MemoryAssets")
  wishlistItems WishlistItem[]

  @@index([coupleSpaceId, sortAt])
}

model MemoryAsset {
  id            String       @id @default(cuid())
  coupleSpaceId String
  authorId      String
  memoryId      String?
  storageKey    String       @unique
  originalUrl   String
  mimeType      String
  width         Int?
  height        Int?
  byteSize      Int?
  blurDataUrl   String?      @db.LongText
  variants      Json?
  status        AssetStatus  @default(PENDING)
  sortOrder     Int          @default(0)
  isCover       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  coupleSpace   CoupleSpace  @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)
  author        User         @relation("AssetAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  memory        Memory?      @relation("MemoryAssets", fields: [memoryId], references: [id], onDelete: SetNull)
  coverFor      Memory?      @relation("MemoryCover")

  @@index([coupleSpaceId, createdAt])
  @@index([memoryId, sortOrder])
}

model Anniversary {
  id            String           @id @default(cuid())
  coupleSpaceId String
  title         String
  note          String?          @db.Text
  targetDate    DateTime
  type          AnniversaryType
  reminderDays  Json
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  coupleSpace   CoupleSpace      @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)
  wishlistItems WishlistItem[]   @relation("WishlistAnniversary")

  @@index([coupleSpaceId, targetDate])
}

model WishlistItem {
  id                String          @id @default(cuid())
  coupleSpaceId     String
  authorId          String
  title             String
  note              String?         @db.Text
  status            WishlistStatus  @default(DREAMING)
  priority          Int             @default(2)
  linkedMemoryId    String?
  linkedAnniversaryId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  coupleSpace       CoupleSpace     @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)
  author            User            @relation("WishlistAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  linkedMemory      Memory?         @relation(fields: [linkedMemoryId], references: [id], onDelete: SetNull)
  linkedAnniversary Anniversary?    @relation("WishlistAnniversary", fields: [linkedAnniversaryId], references: [id], onDelete: SetNull)

  @@index([coupleSpaceId, status, priority])
}

model NotificationSubscription {
  id         String   @id @default(cuid())
  userId      String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationRecord {
  id            String              @id @default(cuid())
  userId        String
  coupleSpaceId String
  channel       NotificationChannel
  title         String
  body          String
  payload       Json?
  status        NotificationStatus  @default(PENDING)
  dedupeKey     String?             @unique
  scheduledFor  DateTime?
  sentAt        DateTime?
  readAt        DateTime?
  createdAt     DateTime            @default(now())
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleSpace   CoupleSpace         @relation(fields: [coupleSpaceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([coupleSpaceId, status])
}

model AuditLog {
  id            String      @id @default(cuid())
  actorUserId    String?
  coupleSpaceId String?
  action        String
  entityType    String
  entityId      String
  meta          Json?
  createdAt     DateTime    @default(now())
  actor         User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  coupleSpace   CoupleSpace? @relation(fields: [coupleSpaceId], references: [id], onDelete: SetNull)
}
